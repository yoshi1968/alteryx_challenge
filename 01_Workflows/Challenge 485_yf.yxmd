      <GuiSettings Plugin="AlteryxBasePluginsGui.MultiRowFormula.MultiRowFormula">
        <Position x="888" y="96" />
      </GuiSettings>
      <Properties>
        <Configuration>
          <UpdateField value="True" />
          <UpdateField_Name>HDPM</UpdateField_Name>
          <CreateField_Name>New Field</CreateField_Name>
          <CreateField_Type>Int32</CreateField_Type>
          <CreateField_Size>4</CreateField_Size>
          <OtherRows>Empty</OtherRows>
          <NumRows value="1" />
          <Expression>IF IsEmpty([Row-1:Contestant])
THEN [HDPM]
ELSE [Row-1:HDPM] - [Drop Rate per Round]
ENDIF</Expression>
          <GroupByFields>
            <Field field="Contestant" />
          </GroupByFields>
        </Configuration>
        <Annotation DisplayMode="0">
