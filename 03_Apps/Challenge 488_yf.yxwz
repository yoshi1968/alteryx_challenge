      </GuiSettings>
      <Properties>
        <Configuration>
          <Caption>Challenge 488</Caption>
          <Style TextColor="#314c4a" FillColor="#ecf2f2" BorderColor="#314c4a" Transparency="25" Margin="25" />
          <Disabled value="False" />
          <Folded value="False" />
